# Backend API base URL (no trailing slash).
# Must match the URL where Laravel is running (e.g. php artisan serve -> http://127.0.0.1:8000/api).
# Use http://127.0.0.1:8000/api or http://localhost:8000/api when running locally.
REACT_APP_API_URL=http://127.0.0.1:8000/api

# If npm start fails with "allowedHosts[0] should be a non-empty string" while using "proxy" in package.json,
# set this (dev only). https://cra.link/advanced-config
# DANGEROUSLY_DISABLE_HOST_CHECK=true
