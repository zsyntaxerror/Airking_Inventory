# Backend API base URL (no trailing slash).
# Local desktop: http://127.0.0.1:8000/api
# Production: set before build, e.g. REACT_APP_API_URL=https://api.yourdomain.com/api
#
# Mobile on Wi‑Fi: .env.development sets HOST=0.0.0.0 so you can open http://YOUR_PC_IP:3000.
# If REACT_APP_API_URL uses localhost/127.0.0.1, the app calls http://YOUR_PC_IP:PORT/api (same host
# as the page). Run Laravel on all interfaces: cd back-end && composer run serve-lan
# (or: php artisan serve --host=0.0.0.0 --port=8000). Allow TCP 8000 in Windows Firewall (Private).
# REACT_APP_API_PORT=8000
# REACT_APP_API_HTTPS=true   # rare: only if API uses HTTPS on LAN
REACT_APP_API_URL=http://127.0.0.1:8000/api

# Dev: required when using package.json "proxy" and opening the app via a LAN IP (see CRA docs).
# DANGEROUSLY_DISABLE_HOST_CHECK=true
