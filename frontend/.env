# Backend API base URL (no trailing slash).
# Must match where Laravel runs: php artisan serve -> http://127.0.0.1:8000/api
REACT_APP_API_URL=http://127.0.0.1:8000/api

# With package.json "proxy" set, CRA enables webpack-dev-server host checks using a LAN IP.
# If no private LAN IP is detected, allowedHosts becomes invalid and the dev server fails to start.
# This restores dev-server behavior (same as having no proxy). See https://cra.link/advanced-config
DANGEROUSLY_DISABLE_HOST_CHECK=true
