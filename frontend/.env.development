# Dev server is plain HTTP only. Do NOT open https:// — the browser will time out (ERR_TIMED_OUT).
# Desktop:  http://localhost:3000/admin/approval-queue   (hyphen, no space in the path)
# Phone:    http://<YOUR_PC_LAN_IP>:3000/...  (same Wi‑Fi; use http unless API also has HTTPS)
# Backend for phones must listen on all interfaces, e.g. from back-end: composer run serve-lan
HTTPS=false
# API port when the app derives http://<same-host-as-page>:PORT/api (default matches artisan serve)
# REACT_APP_API_PORT=8000
# REACT_APP_API_HTTPS=true   # only if your API is served with HTTPS on the LAN host
# Listen on all interfaces so phones on the same Wi‑Fi can reach port 3000
HOST=0.0.0.0
# Fixes "Invalid Host header" when opening the dev server by LAN IP (common with package.json "proxy").
DANGEROUSLY_DISABLE_HOST_CHECK=true
